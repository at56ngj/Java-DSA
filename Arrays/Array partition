import java.util.Arrays;
import java.util.Collections;

class Solution {
    public int arrayPairSum(int[] nums) {
        Arrays.sort(nums);
        int sum=0;
       
        for(int i=1;i<nums.length;i=i+2){
             sum=sum+ Math.min(nums[i-1],nums[i]);
             

        }
       
        return sum;

    }
}
